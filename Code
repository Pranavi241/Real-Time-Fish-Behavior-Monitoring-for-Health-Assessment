# Fish Behavior Monitoring System (Simple Demo)
# Requirements:
# pip install opencv-python numpy

import cv2
import numpy as np

# Open video
video = cv2.VideoCapture("fish_video.mp4")

# Background subtractor for motion detection
fgbg = cv2.createBackgroundSubtractorMOG2()

while True:
    ret, frame = video.read()

    if not ret:
        break

    # Resize frame
    frame = cv2.resize(frame, (800, 600))

    # Apply background subtraction
    mask = fgbg.apply(frame)

    # Remove noise
    kernel = np.ones((5,5), np.uint8)
    mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN, kernel)

    # Find moving objects (fish)
    contours, _ = cv2.findContours(mask, cv2.RETR_TREE, cv2.CHAIN_APPROX_SIMPLE)

    fish_count = 0

    for cnt in contours:
        area = cv2.contourArea(cnt)

        # Ignore small objects
        if area > 500:

            fish_count += 1

            x, y, w, h = cv2.boundingRect(cnt)

            # Draw rectangle around fish
            cv2.rectangle(frame, (x, y), (x+w, y+h), (0,255,0), 2)

            # Calculate movement speed (simple approximation)
            speed = w + h

            # Detect abnormal behavior
            if speed < 60:
                status = "Abnormal Behavior"
                color = (0,0,255)
            else:
                status = "Normal"
                color = (0,255,0)

            cv2.putText(frame, status, (x, y-10),
                        cv2.FONT_HERSHEY_SIMPLEX,
                        0.6, color, 2)

    # Display fish count
    cv2.putText(frame, f"Fish Count: {fish_count}",
                (20,40),
                cv2.FONT_HERSHEY_SIMPLEX,
                1, (255,255,255), 2)

    # Show video
    cv2.imshow("Fish Monitoring System", frame)
    cv2.imshow("Motion Detection", mask)

    # Press Q to exit
    if cv2.waitKey(30) & 0xFF == ord('q'):
        break

video.release()
cv2.destroyAllWindows()
